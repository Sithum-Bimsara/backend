generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                   @id
  name                  String
  email                 String                   @unique
  contactNumber         String?
  isTraveller           Boolean                  @default(true)
  isMerchant            Boolean                  @default(false)
  isAdmin               Boolean                  @default(false)
  status                UserStatus               @default(active)
  createdAt             DateTime                 @default(now())
  address               String?
  city                  String?
  country               String?
  phone                 String?
  phoneVerified         Boolean                  @default(false)
  isMaldivesVerified    Boolean                  @default(false)
  bookings              Booking[]
  accommodationBookings AccommodationBooking[]
  comments              CommunityComment[]
  commentReports        CommunityCommentReport[]
  likes                 CommunityLike[]
  posts                 CommunityPost[]
  postReports           CommunityPostReport[]
  dealLocks             DealLock[]
  dealRequests          DealRequest[]
  dealViewEvents        DealViewEvent[]
  merchantProfile       MerchantProfile?
  searchLogs            SearchLog[]
  interestProfile       UserInterestProfile?
  preferences           UserPreference?
  userRecommendations   UserRecommendations?
  dealReviews           DealReview[]
  accommodationLocks    AccommodationLock[]
  accommodationReviews  AccommodationReview[]
  chatMembers           ChatMember[]
  messages              Message[]
  messageReads          MessageRead[]
}

model MerchantProfile {
  id                          String                     @id @default(uuid())
  userId                      String                     @unique
  businessName                String
  businessDescription         String
  contactNumber               String?
  logoUrl                     String?
  address                     String?
  city                        String?
  country                     String?
  createdAt                   DateTime                   @default(now())
  verificationStatus          MerchantVerificationStatus @default(pending)
  businessRegistrationDocName String?
  businessRegistrationDocUrl  String?
  deals                       Deal[]
  properties                  Property[]
  user                        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus])
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  travelStyle         Json?
  budgetMin           Float?
  budgetMax           Float?
  preferredLocations  Json?
  accommodationTypes  Json?
  activityInterests   Json?
  diverLevel          String?
  tripDuration        String?
  travelGroupType     String?
  transportPreference String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SearchLog {
  id            String   @id @default(uuid())
  userId        String?
  query         String?
  filters       Json?
  createdAt     DateTime @default(now())
  clickedDealId String?
  resultDealIds Json?
  user          User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model DealRequest {
  id            String            @id @default(uuid())
  userId        String
  message       String
  contactNumber String
  status        DealRequestStatus @default(new)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Deal {
  id                 String          @id @default(uuid())
  merchantId         String
  title              String
  description        String
  location           String
  category           String
  durationType       String?
  durationDays       Int
  originalPrice      Float
  primaryImageUrl    String?
  secondImageUrl     String?
  thirdImageUrl      String?
  fourthImageUrl     String?
  dealLockExpireTime Int
  isActive           Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt @default(now())
  dealPrice          Float
  displayedPrice     Float
  isLocalOnly        Boolean         @default(false)
  currency           String          @default("USD")
  averageRating      Float           @default(0)
  totalReviews       Int             @default(0)
  bookings           Booking[]
  merchant           MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  locks              DealLock[]
  stats              InteractionStats?
  variants           DealVariant[]
  viewEvents         DealViewEvent[]
  exclusions         Exclusions[]
  inclusions         Inclusions[]
  itineraries        Itinerary[]
  reviews            DealReview[]
  chatRooms          ChatRoom[]

  @@index([merchantId, createdAt])
  @@index([isActive, location, category])
}

model Itinerary {
  id          String  @id @default(uuid())
  dealId      String
  dayNumber   Int?
  title       String?
  description String?
  deal        Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model DealVariant {
  id             String            @id @default(uuid())
  dealId         String
  originalPrice  Float?
  startDatetime  DateTime?
  totalSlots     Int?
  availableSlots Int?
  status         DealVariantStatus @default(active)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt @default(now())
  displayedPrice Float?
  bookings       Booking[]
  locks          DealLock[]
  deal           Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  slots          VariantSlot[]

  @@unique([dealId, startDatetime])
  @@index([dealId, status, startDatetime])
}

model VariantSlot {
  id         String            @id @default(uuid())
  variantId  String
  slotNumber Int
  status     VariantSlotStatus @default(available)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt @default(now())
  variant    DealVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  bookings   Booking[]         @relation("SlotBookings")
  locks      DealLock[]        @relation("SlotLocks")

  @@unique([variantId, slotNumber])
  @@index([variantId, status])
}

model DealLock {
  id          String        @id @default(uuid())
  userId      String?
  dealId      String?
  variantId   String?
  quantity    Int?
  lockedPrice Float?
  expiresAt   DateTime?
  status      LockStatus
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt @default(now())
  customAddons CustomAddon[]
  bookings    Booking[]
  deal        Deal?         @relation(fields: [dealId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])
  variant     DealVariant?  @relation(fields: [variantId], references: [id])
  slots       VariantSlot[] @relation("SlotLocks")
  chatRooms   ChatRoom[]

  @@index([status, expiresAt])
  @@index([userId])
  @@index([dealId])
  @@index([variantId])
}

model Booking {
  id                   String        @id @default(uuid())
  userId               String?
  dealId               String?
  variantId            String?
  lockId               String?
  quantity             Int?
  totalPrice           Float?
  paymentStatus        BookingStatus
  qrCode               String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt @default(now())
  selectedExclusionIds String[]      @default([])
  customAddons         CustomAddon[]
  deal                 Deal?         @relation(fields: [dealId], references: [id])
  lock                 DealLock?     @relation(fields: [lockId], references: [id])
  user                 User?         @relation(fields: [userId], references: [id])
  variant              DealVariant?  @relation(fields: [variantId], references: [id])
  slots                VariantSlot[] @relation("SlotBookings")

  @@index([userId])
  @@index([dealId])
  @@index([variantId, paymentStatus])
}

model Inclusions {
  id          String  @id @default(uuid())
  dealId      String
  description String?
  deal        Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model Exclusions {
  id              String  @id @default(uuid())
  dealId          String
  description     String?
  additionalPrice Float?
  deal        Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model CommunityPost {
  id        String                @id @default(uuid())
  userId    String
  content   String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt @default(now())
  topic     String
  comments  CommunityComment[]
  likes     CommunityLike[]
  media     CommunityMedia[]
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   CommunityPostReport[]

  @@index([userId])
  @@index([createdAt])
}

model CommunityComment {
  id        String                   @id @default(uuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime                 @default(now())
  parent    CommunityComment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   CommunityComment[]       @relation("CommentReplies")
  post      CommunityPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                     @relation(fields: [userId], references: [id])
  reports   CommunityCommentReport[]
  likes     CommunityLike[]
  media     CommunityMedia[]

  @@index([postId])
  @@index([parentId])
  @@index([userId])
}

model CommunityPostReport {
  id        String        @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model CommunityCommentReport {
  id        String           @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime         @default(now())
  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model CommunityLike {
  id        String            @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime          @default(now())
  comment   CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post      CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])

  @@unique([userId, postId, commentId])
  @@index([postId])
  @@index([commentId])
}

model CommunityMedia {
  id        String            @id @default(uuid())
  url       String
  postId    String?
  commentId String?
  createdAt DateTime          @default(now())
  comment   CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  post      CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([commentId])
}

model DealViewEvent {
  id       String   @id @default(uuid())
  userId   String?
  dealId   String
  viewedAt DateTime @default(now())
  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([dealId])
}

model UserInterestProfile {
  userId               String   @id
  interestedLocations  Json?
  interestedActivities Json?
  accommodationTypes   Json?
  preferredPriceMin    Float?
  preferredPriceMax    Float?
  updatedAt            DateTime @updatedAt @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InteractionStats {
  id            String   @id @default(uuid())
  dealId        String?  @unique
  propertyId    String?  @unique
  totalViews    Int      @default(0)
  totalLocks    Int      @default(0)
  totalBookings Int      @default(0)
  lastUpdated   DateTime @updatedAt @default(now())
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  property      Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([propertyId])
}

model UserRecommendations {
  id        String   @id @default(uuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt @default(now())
  data      Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                 String          @id @default(uuid())
  merchantId         String
  type               PropertyType    @default(apartment)
  name               String?
  description        String?
  address            String?
  city               String?
  island             String?
  zipCode            String?
  latitude           Float?
  longitude          Float?
  propertyFacilities Json?
  services           Json?
  languages          Json?
  checkInFrom        String?
  checkInTo          String?
  checkOutFrom       String?
  checkOutTo         String?
  smokingAllowed     Boolean?
  childrenAllowed    Boolean?
  partiesAllowed     Boolean?
  petsPolicy               Json?
  petFeesPolicy            Json?
  hostProfile              Json?
  starRating               String?
  homeListingType          UnitType        @default(private_room)
  nearbyPointsOfInterest   Json?
  marineLifeZones          Json?
  averageRating      Float           @default(0)
  totalReviews       Int             @default(0)
  isActive                 Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt @default(now())
  merchant           MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  images             PropertyImage[]
  units              Unit[]
  ratePlans          RatePlan[]
  bookings           AccommodationBooking[]
  reviews            AccommodationReview[]
  accommodationLocks AccommodationLock[]
  chatRooms          ChatRoom[]
  stats              InteractionStats?

  @@index([merchantId, createdAt])
  @@index([type, city, island])
  @@index([isActive])
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Unit {
  id             String   @id @default(uuid())
  propertyId     String
  name           String
  maxGuests      Int?
  excludeInfants Boolean  @default(false)
  bathrooms      Float?
  size           Float?
  smokingAllowed Boolean?
  isBathroomPrivate        Boolean?
  bathroomItems            Json?
  cribsAvailable           Boolean?
  roomType                 String?
  pricePerNight  Float?
  localPrice     Float?
  nonLocalPrice Float?
  totalInventory           Int      @default(1)
  dealLockExpireTime       Int      @default(1)
  amenities                Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt @default(now())
  verificationStatus       UnitStatus @default(PENDING)
  property           Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bedConfigs         BedConfiguration[]
  inventory          RoomInventory[]
  ratePlan           RatePlan?
  bookings           AccommodationBooking[]
  accommodationLocks AccommodationLock[]

  @@index([propertyId])
}

model BedConfiguration {
  id        String   @id @default(uuid())
  unitId    String
  bedType   BedType
  count     Int
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@unique([unitId, bedType])
}

model RoomInventory {
  id             String              @id @default(uuid())
  unitId         String
  date           DateTime
  totalRooms     Int
  availableRooms Int
  priceOverride  Float?
  status         RoomInventoryStatus @default(available)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt @default(now())
  unit           Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  slots          RoomVariant[]

  @@unique([unitId, date])
  @@index([unitId, date])
  @@index([status])
}


/// A per-date availability slot for one room number within a RoomInventory day record.
model RoomVariant {
  id          String               @id @default(uuid())
  inventoryId String
  roomNumber  Int                  // Sequential room number within the unit (1-based)
  status      RoomVariantStatus    @default(available)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt @default(now())
  inventory   RoomInventory        @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  bookings    AccommodationBooking[] @relation("RoomBookingSlots")
  locks       AccommodationLock[]    @relation("RoomLockSlots")

  @@unique([inventoryId, roomNumber])
  @@index([inventoryId])
}

enum RoomVariantStatus {
  available
  booked
  maintenance
  blocked
  locked
}

model AccommodationLock {
  id              String               @id @default(uuid())
  userId          String
  propertyId      String
  unitId          String
  checkInDate     DateTime
  checkOutDate    DateTime
  lockedPrice     Float
  expiresAt       DateTime
  quantity        Int
  status          LockStatus           @default(active)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt @default(now())
  customAddons    CustomAddon[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  property        Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit            Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  slots           RoomVariant[]       @relation("RoomLockSlots")
  booking         AccommodationBooking? 
  chatRooms       ChatRoom[]
  
  @@index([userId])
  @@index([status, expiresAt])
}

model AccommodationBooking {
  id          String                     @id @default(uuid())
  userId      String
  propertyId  String
  unitId      String
  lockId      String?                    @unique
  checkInDate DateTime
  checkOutDate DateTime
  guests      Int
  totalPrice  Float
  status      AccommodationBookingStatus @default(pending)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt @default(now())
  customAddons CustomAddon[]
  user        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit        Unit                       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  slots       RoomVariant[]             @relation("RoomBookingSlots")
  lock        AccommodationLock?         @relation(fields: [lockId], references: [id])

  @@index([userId])
  @@index([propertyId, checkInDate, checkOutDate])
  @@index([unitId, status])
}

model RatePlan {
  id                 String        @id @default(uuid())
  propertyId         String
  unitId             String?       @unique
  
  // Explicit cancellation settings
  cancellationWindow           String?   @default("6pm_arrival")
  cancellationFeeType          String?   @default("first_night")
  accidentalBookingProtection  Boolean   @default(true)
  
  occupancyPricingEnabled  Boolean  @default(false)
  occupancyPricing         Json?
  
  childPricingEnabled      Boolean         @default(false)
  childPricingInfantsFree  Boolean         @default(false)
  childPricingChildrenFree Boolean         @default(false)
  childPricingAgeFrom      Int?
  childPricingAgeTo        Int?
  childPricingInfantFixedPrice Float?
  childPricingChildFixedPrice  Float?

  property           Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit               Unit?         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([unitId])
}

model ChatRoom {
  id                  String             @id @default(uuid())
  dealId              String?
  propertyId          String?
  dealLockId          String?            // New: Link to specific deal lock
  accommodationLockId String?            // New: Link to specific accommodation lock
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt @default(now())
  lastMessageAt       DateTime?          @default(now())

  deal              Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  property          Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  dealLock          DealLock?          @relation(fields: [dealLockId], references: [id], onDelete: SetNull)
  accommodationLock AccommodationLock? @relation(fields: [accommodationLockId], references: [id], onDelete: SetNull)
  members           ChatMember[]
  messages          Message[]

  @@index([dealId])
  @@index([propertyId])
  @@index([dealLockId])
  @@index([accommodationLockId])
  @@index([lastMessageAt])
}

model ChatMember {
  id         String   @id @default(uuid())
  chatRoomId String
  userId     String
  joinedAt   DateTime @default(now())

  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([userId])
}

model Message {
  id         String        @id @default(uuid())
  chatRoomId String
  senderId   String
  content    String        @db.Text
  createdAt  DateTime      @default(now())
  
  chatRoom   ChatRoom      @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  readBy     MessageRead[]

  @@index([chatRoomId, createdAt])
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

enum UserStatus {
  active
  suspended
}

enum PropertyType {
  apartment
  home
  hotel
  alternative
}

enum UnitType {
  entire_place
  private_room
  shared
}

enum BedType {
  twin
  full
  queen
  king
  sofa
  bunk
  futon
}

enum RoomInventoryStatus {
  available
  blocked
  sold_out
}

enum AccommodationBookingStatus {
  pending
  confirmed
  cancelled
}

enum DealVariantStatus {
  active
  sold_out
  cancelled
}

enum VariantSlotStatus {
  available
  booked
  locked
  cancelled
}

enum LockStatus {
  active
  expired
  converted
}

enum BookingStatus {
  pending
  paid
  failed
}

enum MerchantVerificationStatus {
  pending
  verified
}

enum DealRequestStatus {
  new
  contacted
  closed
}

enum DealReviewBadgeType {
  normal
  verified
}

model DealReview {
  id        String              @id @default(uuid())
  dealId    String
  userId    String
  rating    Int
  comment   String
  badgeType DealReviewBadgeType @default(normal)
  isEdited  Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([dealId, createdAt])
  @@index([userId])
  @@index([badgeType])
}

model AccommodationReview {
  id         String              @id @default(uuid())
  propertyId String
  userId     String
  rating     Int
  comment    String?             @db.Text
  badgeType  DealReviewBadgeType @default(normal)
  isEdited   Boolean             @default(false)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId, createdAt])
  @@index([userId])
  @@index([badgeType])
}

model CustomAddon {
  id                  String             @id @default(uuid())
  name                String
  price               Float
  details             String?
  addedAt             DateTime           @default(now())
  
  dealLockId          String?
  dealLock            DealLock?          @relation(fields: [dealLockId], references: [id], onDelete: Cascade)
  
  accommodationLockId String?
  accommodationLock   AccommodationLock? @relation(fields: [accommodationLockId], references: [id], onDelete: Cascade)

  dealBookingId       String?
  dealBooking         Booking?           @relation(fields: [dealBookingId], references: [id], onDelete: Cascade)

  accommodationBookingId String?
  accommodationBooking   AccommodationBooking? @relation(fields: [accommodationBookingId], references: [id], onDelete: Cascade)

  @@index([dealLockId])
  @@index([accommodationLockId])
  @@index([dealBookingId])
  @@index([accommodationBookingId])
}

enum UnitStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Island {
  id                    String   @id @default(uuid())
  name                  String
  categories            String[] // Predefined categories: near_airport, local_island, luxury_seaplane, etc.
  overview              String   @db.Text
  bestFor               String   @db.Text
  activities            String[] // Reference to deal taxonomy values (e.g., sunset_cruise, turtle_snorkeling)
  marineLifeZones       String[]
  nightlife             String   @db.Text
  safetyText            String   @db.Text
  internetText          String   @db.Text
  transferDetails       String[]
  
  // Best Time month conditions & notes
  bestTimeMonths        String[] // Array of 12 elements mapping: excellent, good, fair, avoid
  bestTimeTextBest      String?  @db.Text
  bestTimeTextAvoid     String?  @db.Text
  bestTimeTextTips      String?  @db.Text

  // Costs (5 specific fields)
  costLocal             Float    @default(0)
  costNonLocal          Float    @default(0)
  costFoodDrinks        Float    @default(0)
  costActivities        Float    @default(0)
  costExtra             Float    @default(0)

  // Sample Day & Food Deals (JSON structured lists)
  sampleDay             Json?    // [{ time: "09:00", description: "Snorkeling with manta rays" }]
  foodAndDrinkDeals     Json?    // [{ name: "Sunset BBQ", description: "Catch of the day", price: 45.00 }]

  // Insider Tips
  insiderTips           String[] // List of text strings

  // Images
  images                String[] // Max 4 image URLs

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt @default(now())
}
